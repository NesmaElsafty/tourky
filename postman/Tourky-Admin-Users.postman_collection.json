{
	"info": {
		"_postman_id": "a7c3e4b1-9f2d-4c8e-b5a1-0d6e7f8a9b0c",
		"name": "Tourky — Admin Users API",
		"description": "Tests for admin user management: lists (clients/captains/admins), filters, pagination, CRUD, soft block, blocklist, restore.\n\n1. Run **Admin Login** first (sets `admin_token`).\n2. Set `role_id` to a real role id from your DB for **Create admin** (e.g. from `GET /api/admin/roles`).\n3. Set `user_id` after create/show for update/block/restore flows.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8000" },
		{ "key": "admin_token", "value": "" },
		{ "key": "user_id", "value": "1" },
		{ "key": "role_id", "value": "1" }
	],
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }]
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Admin Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
									"const json = pm.response.json();",
									"pm.test('Response has token', function () { pm.expect(json).to.have.property('token'); });",
									"if (json.token) { pm.collectionVariables.set('admin_token', json.token); }"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"01000000001\",\n  \"password\": \"123456\"\n}"
						},
						"url": "{{base_url}}/api/admin/login",
						"description": "Default credentials match AdminUserSeeder (`01000000001` / `123456`). Change if your DB differs."
					}
				}
			]
		},
		{
			"name": "Users — Lists & blocklist",
			"item": [
				{
					"name": "List clients (paginated + filters)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"const j = pm.response.json();",
									"pm.test('Success payload', () => { pm.expect(j.status).to.eql('success'); pm.expect(j).to.have.keys('data','pagination'); });"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "lang", "value": "en" }
						],
						"url": {
							"raw": "{{base_url}}/api/admin/users?type=client&per_page=10&page=1&search=&language=&created_from=&created_to=",
							"host": ["{{base_url}}"],
							"path": ["api", "admin", "users"],
							"query": [
								{ "key": "type", "value": "client" },
								{ "key": "per_page", "value": "10" },
								{ "key": "page", "value": "1" },
								{ "key": "search", "value": "", "disabled": true },
								{ "key": "language", "value": "ar", "disabled": true },
								{ "key": "created_from", "value": "2026-01-01", "disabled": true },
								{ "key": "created_to", "value": "2026-12-31", "disabled": true }
							]
						}
					}
				},
				{
					"name": "List captains",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/api/admin/users?type=captain&per_page=10"
					}
				},
				{
					"name": "List admins (with role filter)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/api/admin/users?type=admin&per_page=10&role_id={{role_id}}"
					}
				},
				{
					"name": "Blocklist — clients",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Blocklist message', () => pm.expect(pm.response.json().status).to.eql('success'));"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/api/admin/users/blocklist?type=client&per_page=10"
					}
				},
				{
					"name": "Blocklist — captains",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/api/admin/users/blocklist?type=captain&per_page=10"
					}
				},
				{
					"name": "Blocklist — admins",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/api/admin/users/blocklist?type=admin&per_page=10"
					}
				}
			]
		},
		{
			"name": "Users — CRUD",
			"item": [
				{
					"name": "Create client",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Created 201', () => pm.response.to.have.status(201));",
									"const j = pm.response.json();",
									"if (j.data && j.data.id) { pm.collectionVariables.set('user_id', String(j.data.id)); }"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Postman Test Client\",\n  \"phone\": \"01999990001\",\n  \"email\": \"postman.client@example.com\",\n  \"password\": \"secret12\",\n  \"password_confirmation\": \"secret12\",\n  \"type\": \"client\",\n  \"language\": \"en\"\n}"
						},
						"url": "{{base_url}}/api/admin/users"
					}
				},
				{
					"name": "Create captain",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Postman Test Captain\",\n  \"phone\": \"01999990002\",\n  \"email\": null,\n  \"password\": \"secret12\",\n  \"password_confirmation\": \"secret12\",\n  \"type\": \"captain\",\n  \"language\": \"ar\"\n}"
						},
						"url": "{{base_url}}/api/admin/users"
					}
				},
				{
					"name": "Create admin (requires role_id)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Postman Test Admin\",\n  \"phone\": \"01999990003\",\n  \"email\": \"postman.admin@example.com\",\n  \"password\": \"secret12\",\n  \"password_confirmation\": \"secret12\",\n  \"type\": \"admin\",\n  \"language\": \"en\",\n  \"role_id\": {{role_id}}\n}"
						},
						"url": "{{base_url}}/api/admin/users",
						"description": "Set collection variable `role_id` to an existing `roles.id` (e.g. run List roles from Roles API or query DB)."
					}
				},
				{
					"name": "Show user (active or blocked)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/api/admin/users/{{user_id}}"
					}
				},
				{
					"name": "Update user (PATCH)",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Postman Client Renamed\",\n  \"language\": \"ar\"\n}"
						},
						"url": "{{base_url}}/api/admin/users/{{user_id}}"
					}
				},
				{
					"name": "Block user (soft delete)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Blocked', () => pm.expect(pm.response.json().message).to.be.a('string'));"
								]
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/api/admin/users/{{user_id}}",
						"description": "Do not use your own admin id — API rejects self-block."
					}
				},
				{
					"name": "Restore user",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200 or 404', () => pm.expect([200,404]).to.include(pm.response.code));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/api/admin/users/{{user_id}}/restore"
					}
				}
			]
		},
		{
			"name": "Roles (helper)",
			"item": [
				{
					"name": "List roles (set role_id)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"const j = pm.response.json();",
									"if (j.data && j.data[0] && j.data[0].id) { pm.collectionVariables.set('role_id', String(j.data[0].id)); }"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/api/admin/roles",
						"description": "Stores first role id into `role_id` for Create admin request."
					}
				}
			]
		},
		{
			"name": "Validation samples",
			"item": [
				{
					"name": "List users — missing type (422)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Unprocessable', () => pm.response.to.have.status(422));"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/api/admin/users"
					}
				},
				{
					"name": "Create admin — missing role_id (422)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Bad Admin\",\n  \"phone\": \"01999990999\",\n  \"password\": \"secret12\",\n  \"password_confirmation\": \"secret12\",\n  \"type\": \"admin\",\n  \"language\": \"en\"\n}"
						},
						"url": "{{base_url}}/api/admin/users"
					}
				}
			]
		}
	]
}
