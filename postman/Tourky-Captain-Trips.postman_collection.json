{
  "info": {
    "_postman_id": "tourky-captain-trips-collection",
    "name": "Tourky - Captain Trips APIs",
    "description": "Captain portal: assigned trips, trip detail + clients, start trip, confirm **arrival** at pickup, confirm **drop-off** (left vehicle), **close** trip.\n\nPrerequisites:\n- Seed DB (captain user + trips with this captain assigned).\n- Default captain: phone `01000000002`, password `123456` (CaptainUserSeeder).\n- If list is empty, create a trip in Admin first with this captain's `captain_id`.\n\nRun order:\n1) Captain Login\n2) List assigned trips\n3) Show trip (sets `reservation_id` from first client)\n4) Start trip (planned → in_progress) — **required before close**\n5) Confirm **arrival** at pickup (`PATCH .../pickup`)\n6) Confirm passenger **left the car** (`PATCH .../dropoff`) — requires arrival first\n7) **Close** trip (`POST .../close`) — requires `in_progress`\n\nSet `baseUrl` to your API root, e.g. http://127.0.0.1:8000/api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000/api" },
    { "key": "captain_phone", "value": "01000000002" },
    { "key": "captain_password", "value": "123456" },
    { "key": "captain_token", "value": "" },
    { "key": "trip_id", "value": "" },
    { "key": "reservation_id", "value": "" },
    { "key": "per_page", "value": "10" }
  ],
  "item": [
    {
      "name": "1) Captain Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const j = pm.response.json();",
              "pm.test('Token exists', function () { pm.expect(j.token).to.be.a('string'); });",
              "if (j.token) pm.collectionVariables.set('captain_token', j.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json", "type": "text" },
          { "key": "Accept", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{captain_phone}}\",\n  \"password\": \"{{captain_password}}\"\n}"
        },
        "url": "{{baseUrl}}/captain/login"
      }
    },
    {
      "name": "2) List assigned trips",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const j = pm.response.json();",
              "pm.test('Has data array', function () { pm.expect(j.data).to.be.an('array'); });",
              "if (Array.isArray(j.data) && j.data.length && j.data[0].id) {",
              "  pm.collectionVariables.set('trip_id', String(j.data[0].id));",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{captain_token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
        "url": "{{baseUrl}}/captain/trips?per_page={{per_page}}"
      }
    },
    {
      "name": "3) Show trip (clients on my vehicle)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 or 404', function () { pm.expect([200, 404]).to.include(pm.response.code); });",
              "if (pm.response.code !== 200) return;",
              "const j = pm.response.json();",
              "pm.test('Trip payload', function () { pm.expect(j.data).to.be.an('object'); });",
              "pm.test('Has clients array', function () { pm.expect(j.data.clients).to.be.an('array'); });",
              "if (j.data && j.data.clients && j.data.clients.length && j.data.clients[0].reservation_id) {",
              "  pm.collectionVariables.set('reservation_id', String(j.data.clients[0].reservation_id));",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{captain_token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
        "url": "{{baseUrl}}/captain/trips/{{trip_id}}"
      }
    },
    {
      "name": "4) Start trip (planned → in_progress)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 or 422', function () { pm.expect([200, 422]).to.include(pm.response.code); });",
              "if (pm.response.code === 200) {",
              "  const j = pm.response.json();",
              "  pm.test('Trip status in response', function () { pm.expect(j.data && j.data.status).to.exist; });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{captain_token}}", "type": "string" }]
        },
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
        "url": "{{baseUrl}}/captain/trips/{{trip_id}}/start"
      }
    },
    {
      "name": "5) Confirm arrival at pickup",
      "description": "Sets `picked_up_at` / `arrived_at` — passenger met the captain at the pickup point.",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 or 422', function () { pm.expect([200, 422]).to.include(pm.response.code); });",
              "if (pm.response.code === 200) {",
              "  const j = pm.response.json();",
              "  pm.test('picked_up_at in payload', function () {",
              "    pm.expect(j.data && j.data.picked_up_at).to.exist;",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{captain_token}}", "type": "string" }]
        },
        "method": "PATCH",
        "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
        "url": "{{baseUrl}}/captain/trips/{{trip_id}}/reservations/{{reservation_id}}/pickup"
      }
    },
    {
      "name": "6) Confirm passenger left the vehicle",
      "description": "Sets `dropped_off_at` — requires arrival (step 5) first.",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 or 422', function () { pm.expect([200, 422]).to.include(pm.response.code); });",
              "if (pm.response.code === 200) {",
              "  const j = pm.response.json();",
              "  pm.test('dropped_off_at in payload', function () {",
              "    pm.expect(j.data && j.data.dropped_off_at).to.exist;",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{captain_token}}", "type": "string" }]
        },
        "method": "PATCH",
        "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
        "url": "{{baseUrl}}/captain/trips/{{trip_id}}/reservations/{{reservation_id}}/dropoff"
      }
    },
    {
      "name": "7) Close trip (end run)",
      "description": "Sets trip status to `completed`. Trip must be `in_progress` (use step 4 first).",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 or 422', function () { pm.expect([200, 422]).to.include(pm.response.code); });",
              "if (pm.response.code === 200) {",
              "  const j = pm.response.json();",
              "  pm.test('Trip completed', function () { pm.expect(j.data && j.data.status).to.eql('completed'); });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{captain_token}}", "type": "string" }]
        },
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
        "url": "{{baseUrl}}/captain/trips/{{trip_id}}/close"
      }
    }
  ]
}
