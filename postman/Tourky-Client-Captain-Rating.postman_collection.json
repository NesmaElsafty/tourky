{
  "info": {
    "_postman_id": "tourky-client-captain-rating-only",
    "name": "Tourky - Client Captain Rating (only)",
    "description": "**Isolated collection** to test `POST /client/trips/{reservation}/captain-rating` only.\n\n1. **Client Login** → saves `client_token`.\n2. **Pick reservation from history** (optional) → sets `reservation_id` from first trip, or paste `reservation_id` yourself.\n3. **Rate captain** — requires `dropped_off_at` set by captain; one rating per reservation.\n\n**Variables:** `baseUrl`, `client_phone`, `client_password`, `client_token`, `reservation_id`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000/api" },
    { "key": "client_phone", "value": "01000000003" },
    { "key": "client_password", "value": "password" },
    { "key": "client_token", "value": "" },
    { "key": "reservation_id", "value": "" }
  ],
  "item": [
    {
      "name": "1) Client Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const j = pm.response.json();",
              "pm.test('Token', function () { pm.expect(j.token).to.be.a('string'); });",
              "if (j.token) pm.collectionVariables.set('client_token', j.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json", "type": "text" },
          { "key": "Accept", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{client_phone}}\",\n  \"password\": \"{{client_password}}\"\n}"
        },
        "url": "{{baseUrl}}/client/login"
      }
    },
    {
      "name": "2) Pick reservation_id (history list)",
      "description": "Sets `reservation_id` from the first booking in history. Skip if you already set `reservation_id` manually.",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const j = pm.response.json();",
              "if (j.data && j.data.length && j.data[0].reservation_id) {",
              "  pm.collectionVariables.set('reservation_id', String(j.data[0].reservation_id));",
              "  pm.test('Saved reservation_id', function () { pm.expect(pm.collectionVariables.get('reservation_id')).to.match(/^\\d+$/); });",
              "} else {",
              "  pm.test('Has at least one trip (or set reservation_id manually)', function () { pm.expect(j.data && j.data.length).to.be.above(0); });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{client_token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
        "url": "{{baseUrl}}/client/trips?scope=history&per_page=20"
      }
    },
    {
      "name": "3) POST captain-rating",
      "description": "Body: `rating` 1–5, optional `feedback`. Expect **200** if drop-off was confirmed and not yet rated; **422** otherwise.",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const code = pm.response.code;",
              "pm.test('200 success or expected errors', function () {",
              "  pm.expect([200, 404, 422]).to.include(code);",
              "});",
              "if (code === 200) {",
              "  const j = pm.response.json();",
              "  pm.test('captain_rating on data', function () {",
              "    pm.expect(j.data.captain_rating).to.be.within(1, 5);",
              "    pm.expect(j.data.can_rate_captain).to.eql(false);",
              "  });",
              "}",
              "if (code === 422) {",
              "  const j = pm.response.json();",
              "  pm.test('Validation message', function () { pm.expect(j.message || j.errors).to.exist; });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{client_token}}", "type": "string" }]
        },
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json", "type": "text" },
          { "key": "Accept", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rating\": 5,\n  \"feedback\": \"Testing captain rating from Postman.\"\n}"
        },
        "url": "{{baseUrl}}/client/trips/{{reservation_id}}/captain-rating"
      }
    }
  ]
}
