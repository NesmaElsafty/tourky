{
  "info": {
    "_postman_id": "tourky-client-trips-collection",
    "name": "Tourky - Client Trips",
    "description": "## Client trip list & detail\n\n**Base URL:** set collection variable `baseUrl` (e.g. `http://127.0.0.1:8000/api`).\n\n### Auth\nRun **Client Login** — saves `client_token`.\n\n### Trips\n- **List trips** — `scope` = `upcoming` | `history` | `today` (required).\n- **Trip detail** — `GET /client/trips/{reservation_id}`.\n\n### Captain rating (separate collection)\nUse **`Tourky-Client-Captain-Rating.postman_collection.json`** to test `POST .../captain-rating` only.\n\n### Variables\n`client_phone` / `client_password` (defaults: `01000000003` / `password`), `reservation_id` (set from list requests or paste).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000/api" },
    { "key": "client_phone", "value": "01000000003" },
    { "key": "client_password", "value": "password" },
    { "key": "client_token", "value": "" },
    { "key": "reservation_id", "value": "" },
    { "key": "per_page", "value": "15" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Client Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const j = pm.response.json();",
                  "pm.test('Has token', function () { pm.expect(j.token).to.be.a('string'); });",
                  "if (j.token) pm.collectionVariables.set('client_token', j.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{client_phone}}\",\n  \"password\": \"{{client_password}}\"\n}"
            },
            "url": "{{baseUrl}}/client/login"
          }
        }
      ]
    },
    {
      "name": "Trips",
      "item": [
        {
          "name": "List — upcoming",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const j = pm.response.json();",
                  "pm.test('Success payload', function () { pm.expect(j.status).to.eql('success'); pm.expect(j.data).to.be.an('array'); });",
                  "if (j.data && j.data.length && j.data[0].reservation_id) {",
                  "  pm.collectionVariables.set('reservation_id', String(j.data[0].reservation_id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{client_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
            "url": "{{baseUrl}}/client/trips?scope=upcoming&per_page={{per_page}}"
          }
        },
        {
          "name": "List — history",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const j = pm.response.json();",
                  "pm.test('Pagination or array', function () {",
                  "  pm.expect(j.data).to.be.an('array');",
                  "  if (j.pagination) pm.expect(j.pagination).to.be.an('object');",
                  "});",
                  "if (j.data && j.data.length && j.data[0].reservation_id) {",
                  "  pm.collectionVariables.set('reservation_id', String(j.data[0].reservation_id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{client_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
            "url": "{{baseUrl}}/client/trips?scope=history&per_page={{per_page}}"
          }
        },
        {
          "name": "List — today",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const j = pm.response.json();",
                  "pm.test('Data array', function () { pm.expect(j.data).to.be.an('array'); });",
                  "if (j.data && j.data.length && j.data[0].reservation_id) {",
                  "  pm.collectionVariables.set('reservation_id', String(j.data[0].reservation_id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{client_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
            "url": "{{baseUrl}}/client/trips?scope=today&per_page={{per_page}}"
          }
        },
        {
          "name": "Trip detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 or 404', function () { pm.expect([200, 404]).to.include(pm.response.code); });",
                  "if (pm.response.code !== 200) return;",
                  "const j = pm.response.json();",
                  "pm.test('Trip fields', function () {",
                  "  pm.expect(j.data.reservation_id).to.exist;",
                  "  pm.expect(j.data).to.have.keys('has_left_vehicle', 'can_rate_captain', 'captain_rating', 'captain_feedback');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{client_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
            "url": "{{baseUrl}}/client/trips/{{reservation_id}}"
          }
        }
      ]
    }
  ]
}
