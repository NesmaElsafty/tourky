{
	"info": {
		"_postman_id": "f7a2b9c1-forgot-pw-0001",
		"name": "Tourky — Forgot password (OTP)",
		"description": "Tests admin and client forgot-password flows (email OTP → verify → reset).\n\n**Setup**\n1. Set `baseUrl` (default `http://localhost:8000/api`).\n2. Configure `MAIL_*` in `.env` and use a mail catcher (Mailpit, Mailtrap, log driver, etc.).\n3. Ensure seeded users exist (`AdminUserSeeder`, `ClientUserSeeder`) or adjust `adminEmail` / `clientEmail`.\n\n**Per portal run order**\n1. **Forgot password** — sends OTP to email.\n2. Copy the OTP from the email into collection variable **`otp`** (Postman → Variables).\n3. **Verify OTP** — saves `reset_token` to `adminResetToken` or `clientResetToken`.\n4. **Reset password** — uses that token and `newPassword` / `newPassword` confirmation.\n\nThrottling: do not hammer endpoints (6/min on send & reset).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8000/api" },
		{ "key": "adminEmail", "value": "admin@tourky.local" },
		{ "key": "clientEmail", "value": "client@tourky.local" },
		{ "key": "otp", "value": "" },
		{ "key": "newPassword", "value": "NewPass123456" },
		{ "key": "adminResetToken", "value": "" },
		{ "key": "clientResetToken", "value": "" }
	],
	"item": [
		{
			"name": "Admin — forgot password",
			"item": [
				{
					"name": "1. Forgot password (send OTP)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
									"const j = pm.response.json();",
									"pm.test('Has message', function () { pm.expect(j.message).to.be.a('string').that.is.not.empty; });"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "lang", "value": "en" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{adminEmail}}\"\n}"
						},
						"url": "{{baseUrl}}/admin/forgot-password",
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "2. Verify OTP",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"const otp = pm.collectionVariables.get('otp') || '';",
									"if (!/^\\d{4,8}$/.test(otp)) {",
									"  console.warn('Set collection variable `otp` to the code from the email (4–8 digits) before running Verify OTP.');",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('HTTP 200 on success', function () {",
									"  pm.expect([200, 422]).to.include(pm.response.code);",
									"});",
									"const j = pm.response.json();",
									"if (pm.response.code === 200) {",
									"  pm.test('Has reset_token', function () {",
									"    pm.expect(j.reset_token).to.be.a('string').that.is.not.empty;",
									"  });",
									"  if (j.reset_token) { pm.collectionVariables.set('adminResetToken', j.reset_token); }",
									"} else {",
									"  pm.test('Error message on failure', function () { pm.expect(j.message).to.be.a('string'); });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "lang", "value": "en" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"otp\": \"{{otp}}\"\n}"
						},
						"url": "{{baseUrl}}/admin/forgot-password/verify-otp",
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "3. Reset password",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('HTTP 200 on success', function () {",
									"  pm.expect([200, 422]).to.include(pm.response.code);",
									"});",
									"const j = pm.response.json();",
									"if (pm.response.code === 200) {",
									"  pm.test('Success message', function () { pm.expect(j.message).to.be.a('string'); });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "lang", "value": "en" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"reset_token\": \"{{adminResetToken}}\",\n  \"password\": \"{{newPassword}}\",\n  \"password_confirmation\": \"{{newPassword}}\"\n}"
						},
						"url": "{{baseUrl}}/admin/forgot-password/reset",
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "4. Login with new password (sanity)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
									"const j = pm.response.json();",
									"pm.test('Has token', function () { pm.expect(j.token).to.be.a('string').that.is.not.empty; });"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"01000000001\",\n  \"password\": \"{{newPassword}}\"\n}"
						},
						"url": "{{baseUrl}}/admin/login",
						"auth": { "type": "noauth" }
					}
				}
			]
		},
		{
			"name": "Client — forgot password",
