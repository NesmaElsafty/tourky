{
	"info": {
		"_postman_id": "a1b2c3d4-tickets-admin-0001",
		"name": "Tourky — Admin tickets",
		"description": "Tests admin ticket API.\n\n1. Set `baseUrl` (default `http://localhost:8000/api`).\n2. Run **Login** (demo admin `01000000001` / `123456`); token is saved to `token`.\n3. Run **List tickets** to populate `ticketIdEditable`, `ticketIdLocked`, `ticketIdForReply` from seeded `[SEED]` titles (requires `php artisan db:seed --class=TicketSeeder` or full `db:seed`).\n4. Run show / reply / status requests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8000/api" },
		{ "key": "token", "value": "" },
		{ "key": "ticketIdEditable", "value": "" },
		{ "key": "ticketIdLocked", "value": "" },
		{ "key": "ticketIdForReply", "value": "" }
	],
	"item": [
		{
			"name": "Login (admin)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
							"const j = pm.response.json();",
							"pm.test('Has bearer token', function () { pm.expect(j.token).to.be.a('string').that.is.not.empty; });",
							"if (j.token) { pm.collectionVariables.set('token', j.token); }"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Accept", "value": "application/json" },
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"phone\": \"01000000001\",\n  \"password\": \"123456\"\n}"
				},
				"url": "{{baseUrl}}/admin/login",
				"auth": { "type": "noauth" }
			}
		},
		{
			"name": "List tickets",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
							"const j = pm.response.json();",
							"pm.test('status success', function () { pm.expect(j.status).to.eql('success'); });",
							"pm.test('data is array', function () { pm.expect(j.data).to.be.an('array'); });",
							"const rows = j.data || [];",
							"function capture(sub, varName) {",
							"  const row = rows.find(function (t) { return (t.title || '').indexOf(sub) !== -1; });",
							"  if (row) { pm.collectionVariables.set(varName, String(row.id)); }",
							"}",
							"capture('pending, no admin reply', 'ticketIdEditable');",
							"capture('admin replied (locked', 'ticketIdLocked');",
							"capture('for admin reply POST', 'ticketIdForReply');"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [{ "key": "Accept", "value": "application/json" }],
				"url": "{{baseUrl}}/admin/tickets?per_page=50",
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
				}
			}
		},
		{
			"name": "List tickets (status=pending)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
							"const j = pm.response.json();",
							"pm.test('status success', function () { pm.expect(j.status).to.eql('success'); });",
							"const rows = j.data || [];",
							"rows.forEach(function (t) { pm.expect(t.status).to.eql('pending'); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [{ "key": "Accept", "value": "application/json" }],
				"url": "{{baseUrl}}/admin/tickets?status=pending&per_page=50",
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
				}
			}
		},
		{
			"name": "Get ticket (editable seed)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
							"const j = pm.response.json();",
							"pm.test('status success', function () { pm.expect(j.status).to.eql('success'); });",
							"pm.test('has client and trip payload keys', function () {",
							"  pm.expect(j.data).to.have.keys('id', 'title', 'status', 'messages', 'client');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [{ "key": "Accept", "value": "application/json" }],
				"url": "{{baseUrl}}/admin/tickets/{{ticketIdEditable}}",
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
				}
			}
		},
		{
			"name": "Reply to ticket (for-reply seed)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
							"const j = pm.response.json();",
							"pm.test('status success', function () { pm.expect(j.status).to.eql('success'); });",
							"pm.test('messages include admin reply', function () {",
							"  const msgs = j.data.messages || [];",
							"  pm.expect(msgs.length).to.be.at.least(1);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Accept", "value": "application/json" },
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"message\": \"Postman admin reply: thanks for the details, we will follow up shortly.\"\n}"
				},
				"url": "{{baseUrl}}/admin/tickets/{{ticketIdForReply}}/reply",
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
				}
			}
		},
		{
			"name": "Update ticket status (locked seed)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
							"const j = pm.response.json();",
							"pm.test('status success', function () { pm.expect(j.status).to.eql('success'); });",
							"pm.test('ticket status updated', function () { pm.expect(j.data.status).to.eql('solved'); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [
					{ "key": "Accept", "value": "application/json" },
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"status\": \"solved\"\n}"
				},
				"url": "{{baseUrl}}/admin/tickets/{{ticketIdLocked}}/status",
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
				}
			}
		}
	]
}
