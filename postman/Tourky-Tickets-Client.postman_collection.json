{
	"info": {
		"_postman_id": "a1b2c3d4-tickets-client-0002",
		"name": "Tourky — Client tickets",
		"description": "Tests client ticket API.\n\n1. Set `baseUrl` (default `http://localhost:8000/api`).\n2. Run **Login** (demo client `01000000003` / `123456`).\n3. Run **List tickets** to set `ticketIdEditable` and `ticketIdLocked` from `[SEED]` rows (`TicketSeeder`).\n4. Run show / update / create / delete; locked-row update/delete expect **422**.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8000/api" },
		{ "key": "token", "value": "" },
		{ "key": "ticketIdEditable", "value": "" },
		{ "key": "ticketIdLocked", "value": "" },
		{ "key": "ticketIdCreated", "value": "" }
	],
	"item": [
		{
			"name": "Login (client)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
							"const j = pm.response.json();",
							"pm.test('Has bearer token', function () { pm.expect(j.token).to.be.a('string').that.is.not.empty; });",
							"if (j.token) { pm.collectionVariables.set('token', j.token); }"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Accept", "value": "application/json" },
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"phone\": \"01000000003\",\n  \"password\": \"123456\"\n}"
				},
				"url": "{{baseUrl}}/client/login",
				"auth": { "type": "noauth" }
			}
		},
		{
			"name": "List tickets",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
							"const j = pm.response.json();",
							"pm.test('status success', function () { pm.expect(j.status).to.eql('success'); });",
							"pm.test('data is array', function () { pm.expect(j.data).to.be.an('array'); });",
							"const rows = j.data || [];",
							"function capture(sub, varName) {",
							"  const row = rows.find(function (t) { return (t.title || '').indexOf(sub) !== -1; });",
							"  if (row) { pm.collectionVariables.set(varName, String(row.id)); }",
							"}",
							"capture('pending, no admin reply', 'ticketIdEditable');",
							"capture('admin replied (locked', 'ticketIdLocked');"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [{ "key": "Accept", "value": "application/json" }],
				"url": "{{baseUrl}}/client/tickets?per_page=50",
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
				}
			}
		},
		{
			"name": "Get ticket (editable)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
							"const j = pm.response.json();",
							"pm.test('status success', function () { pm.expect(j.status).to.eql('success'); });",
							"pm.test('can edit when no admin reply', function () {",
							"  pm.expect(j.data.can_edit).to.eql(true);",
							"  pm.expect(j.data.can_delete).to.eql(true);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [{ "key": "Accept", "value": "application/json" }],
				"url": "{{baseUrl}}/client/tickets/{{ticketIdEditable}}",
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
				}
			}
		},
		{
			"name": "Update ticket (editable)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
							"const j = pm.response.json();",
							"pm.test('status success', function () { pm.expect(j.status).to.eql('success'); });",
							"pm.test('title updated', function () { pm.expect(j.data.title).to.include('(updated)'); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [
					{ "key": "Accept", "value": "application/json" },
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"[SEED] Demo — pending, no admin reply (updated)\",\n  \"description\": \"Updated from Postman client collection.\"\n}"
				},
				"url": "{{baseUrl}}/client/tickets/{{ticketIdEditable}}",
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
				}
			}
		},
		{
			"name": "Update ticket (locked — expect 422)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 422', function () { pm.response.to.have.status(422); });",
							"const j = pm.response.json();",
							"pm.test('validation errors', function () { pm.expect(j.errors || j.message).to.exist; });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [
					{ "key": "Accept", "value": "application/json" },
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"Should not apply\"\n}"
				},
				"url": "{{baseUrl}}/client/tickets/{{ticketIdLocked}}",
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
				}
			}
		},
		{
			"name": "Create ticket",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 201', function () { pm.response.to.have.status(201); });",
							"const j = pm.response.json();",
							"pm.test('status success', function () { pm.expect(j.status).to.eql('success'); });",
							"pm.test('has id', function () { pm.expect(j.data.id).to.be.a('number'); });",
							"if (j.data && j.data.id) { pm.collectionVariables.set('ticketIdCreated', String(j.data.id)); }"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Accept", "value": "application/json" },
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"Postman temp ticket\",\n  \"description\": \"Created by Postman client collection for delete test.\"\n}"
				},
				"url": "{{baseUrl}}/client/tickets",
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
				}
			}
		},
		{
			"name": "Delete ticket (created)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
							"const j = pm.response.json();",
							"pm.test('status success', function () { pm.expect(j.status).to.eql('success'); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [{ "key": "Accept", "value": "application/json" }],
				"url": "{{baseUrl}}/client/tickets/{{ticketIdCreated}}",
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
				}
			}
		},
		{
			"name": "Delete ticket (locked — expect 422)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('HTTP 422', function () { pm.response.to.have.status(422); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [{ "key": "Accept", "value": "application/json" }],
				"url": "{{baseUrl}}/client/tickets/{{ticketIdLocked}}",
				"auth": {
					"type": "bearer",
					"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
				}
			}
		}
	]
}
