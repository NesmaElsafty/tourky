# HTTP server for Socket.io
PORT=6001
HOST=0.0.0.0

# Laravel API (same Sanctum bearer tokens as mobile app)
LARAVEL_URL=http://127.0.0.1:8000
TRACKING_INTERNAL_SECRET=

# Redis: pub/sub for Socket.io adapter + short-lived auth cache
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=tracking:

# Reduce repeated HTTP calls to Laravel (seconds)
AUTH_CACHE_TTL_SECONDS=45
TRIP_AUTH_CACHE_TTL_SECONDS=30

# Axios timeout when calling Laravel (ms)
HTTP_TIMEOUT_MS=3500

# Location emit throttle per socket + trip (milliseconds)
LOC_MIN_INTERVAL_MS=400

# Socket.io: reject oversized payloads early (bytes)
MAX_HTTP_BUFFER_SIZE=512

# Comma-separated origins for browser clients; leave empty for "*"
# Flutter/native apps often omit Origin — keep permissive unless you expose a web admin UI.
CORS_ORIGINS=
